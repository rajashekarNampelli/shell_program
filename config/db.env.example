# Copy this file to db.env and fill in your CockroachDB connection details.
# cp config/db.env.example config/db.env

DB_HOST=your-host-url
DB_PORT=26257
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password_or_jwt_token

# Auth mode: password or JWT (AWS-hosted, port 443)
AUTH_MODE=JWT

# Output CSV base path (timestamp and .csv are appended automatically)
# e.g. output/employee_export → output/employee_export_20260629_191300.csv
OUTPUT_FILE=output/employee_export

# SQL query to run
SQL_QUERY=SELECT * FROM employee
