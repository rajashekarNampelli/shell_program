# Copy this file to db.env and fill in your CockroachDB connection details.
# cp config/db.env.example config/db.env

DB_HOST=your-host-url
DB_PORT=26257
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password_or_jwt_token

# Set to true for JWT auth (AWS-hosted, port 443), false for standard password auth
JWT_AUTH_CONNECTION=false
